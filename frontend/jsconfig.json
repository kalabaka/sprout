{
  "compilerOptions": {
    "target": "ES6",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "jsx": "preserve",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "lib": ["ES6", "DOM"],
    "strict": false,
    "noImplicitAny": false
  },
  "include": [
    "src/**/*",
    "*.js",
    "*.vue"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
